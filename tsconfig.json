{
	"compilerOptions": {
		"target": "es2024",

		"module": "ESNext",
		"moduleResolution": "nodenext",

		"declaration": true,
		"outDir": "dist",

		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,

		"sourceMap": false,
		"skipLibCheck": true,
		"strict": true
	},
	"lib": ["es2024"]
}
